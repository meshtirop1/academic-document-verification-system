{
  "name": "academic-integrity-verification-system",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "remix vite:build",
    "dev": "remix vite:dev",
    "start": "remix-serve ./build/server/index.js",
    "typecheck": "tsc",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "chain": "npx hardhat node",
    "deploy:contract": "node scripts/deploy.cjs",
    "seed": "node scripts/seed.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:contract": "npx hardhat test --config hardhat.config.cjs",
    "test:all": "npm run test:contract && npm run test"
  },
  "dependencies": {
    "@prisma/client": "^5.15.0",
    "@remix-run/node": "^2.12.0",
    "@remix-run/react": "^2.12.0",
    "@remix-run/serve": "^2.12.0",
    "bcryptjs": "^2.4.3",
    "ethers": "^6.13.0",
    "html2canvas": "^1.4.1",
    "isbot": "^4.4.0",
    "jspdf": "^4.2.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@remix-run/dev": "^2.12.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.10",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.4.19",
    "happy-dom": "^20.10.2",
    "hardhat": "^2.22.5",
    "postcss": "^8.4.39",
    "pptxgenjs": "^4.0.1",
    "prisma": "^5.15.0",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^4.1.8"
  }
}
